<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.falconx.market.repository.mapper.MarketSymbolMapper">

    <resultMap id="MarketSymbolRecordMap" type="com.falconx.market.repository.mapper.record.MarketSymbolRecord">
        <constructor>
            <arg column="id" javaType="java.lang.Long"/>
            <arg column="symbol" javaType="java.lang.String"/>
            <arg column="category" javaType="_int"/>
            <arg column="market_code" javaType="java.lang.String"/>
            <arg column="base_currency" javaType="java.lang.String"/>
            <arg column="quote_currency" javaType="java.lang.String"/>
            <arg column="price_precision" javaType="_int"/>
            <arg column="qty_precision" javaType="_int"/>
            <arg column="min_qty" javaType="java.math.BigDecimal"/>
            <arg column="max_qty" javaType="java.math.BigDecimal"/>
            <arg column="min_notional" javaType="java.math.BigDecimal"/>
            <arg column="max_leverage" javaType="_int"/>
            <arg column="taker_fee_rate" javaType="java.math.BigDecimal"/>
            <arg column="spread" javaType="java.math.BigDecimal"/>
            <arg column="status" javaType="_int"/>
        </constructor>
    </resultMap>

    <sql id="MarketSymbolColumns">
        id,
        symbol,
        category,
        market_code,
        base_currency,
        quote_currency,
        price_precision,
        qty_precision,
        min_qty,
        max_qty,
        min_notional,
        max_leverage,
        taker_fee_rate,
        spread,
        status
    </sql>

    <select id="selectAllTradingSymbols" resultMap="MarketSymbolRecordMap">
        SELECT
        <include refid="MarketSymbolColumns"/>
        FROM t_symbol
        WHERE status = 1
        ORDER BY id ASC
    </select>

    <select id="selectBySymbol" resultMap="MarketSymbolRecordMap">
        SELECT
        <include refid="MarketSymbolColumns"/>
        FROM t_symbol
        WHERE symbol = #{symbol}
    </select>
</mapper>
