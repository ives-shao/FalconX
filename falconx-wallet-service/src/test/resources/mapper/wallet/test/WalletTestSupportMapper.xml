<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.falconx.wallet.repository.mapper.test.WalletTestSupportMapper">

    <delete id="deleteOutbox">DELETE FROM t_outbox</delete>
    <delete id="deleteWalletChainCursor">DELETE FROM t_wallet_chain_cursor</delete>
    <delete id="deleteWalletDepositTransaction">DELETE FROM t_wallet_deposit_tx</delete>
    <delete id="deleteWalletAddress">DELETE FROM t_wallet_address</delete>

    <select id="countWalletAddressByUserId" resultType="java.lang.Integer">
        SELECT COUNT(1)
        FROM t_wallet_address
        WHERE user_id = #{userId}
    </select>

    <select id="countWalletDepositByUserId" resultType="java.lang.Integer">
        SELECT COUNT(1)
        FROM t_wallet_deposit_tx
        WHERE user_id = #{userId}
    </select>

    <select id="countConfirmedDepositByTxHash" resultType="java.lang.Integer">
        SELECT COUNT(1)
        FROM t_wallet_deposit_tx
        WHERE tx_hash = #{txHash}
          AND status = 2
    </select>

    <select id="selectWalletDepositStatusByTxHash" resultType="java.lang.Integer">
        SELECT status
        FROM t_wallet_deposit_tx
        WHERE tx_hash = #{txHash}
    </select>

    <select id="selectConfirmedAtByTxHash" resultType="java.time.OffsetDateTime">
        SELECT confirmed_at
        FROM t_wallet_deposit_tx
        WHERE tx_hash = #{txHash}
    </select>

    <select id="countOutbox" resultType="java.lang.Integer">
        SELECT COUNT(1)
        FROM t_outbox
    </select>

    <select id="countOutboxByEventType" resultType="java.lang.Integer">
        SELECT COUNT(1)
        FROM t_outbox
        WHERE event_type = #{eventType}
    </select>

    <select id="selectLatestOutboxPayloadByEventType" resultType="java.lang.String">
        SELECT payload_json
        FROM t_outbox
        WHERE event_type = #{eventType}
        ORDER BY created_at DESC, id DESC
        LIMIT 1
    </select>
</mapper>
