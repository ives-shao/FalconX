<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.falconx.market.repository.mapper.MarketSwapRateMapper">

    <resultMap id="MarketSwapRateRecordMap" type="com.falconx.market.repository.mapper.record.MarketSwapRateRecord">
        <constructor>
            <arg column="id" javaType="java.lang.Long"/>
            <arg column="symbol" javaType="java.lang.String"/>
            <arg column="long_rate" javaType="java.math.BigDecimal"/>
            <arg column="short_rate" javaType="java.math.BigDecimal"/>
            <arg column="rollover_time" javaType="java.time.LocalTime"/>
            <arg column="effective_from" javaType="java.time.LocalDate"/>
            <arg column="created_at" javaType="java.time.LocalDateTime"/>
            <arg column="updated_at" javaType="java.time.LocalDateTime"/>
        </constructor>
    </resultMap>

    <select id="selectAllOrdered" resultMap="MarketSwapRateRecordMap">
        SELECT id,
               symbol,
               long_rate,
               short_rate,
               rollover_time,
               effective_from,
               created_at,
               updated_at
        FROM t_swap_rate
        ORDER BY symbol ASC, effective_from ASC, id ASC
    </select>
</mapper>
