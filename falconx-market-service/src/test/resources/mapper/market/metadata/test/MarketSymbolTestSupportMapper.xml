<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.falconx.market.repository.mapper.test.MarketSymbolTestSupportMapper">

    <update id="updateSymbolStatus">
        UPDATE t_symbol
        SET status = #{status}
        WHERE symbol = #{symbol}
    </update>
</mapper>
