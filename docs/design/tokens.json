{
  "global": {
    "color": {
      "neutral": {
        "0": { "$value": "#F8FBFF", "$type": "color" },
        "100": { "$value": "#E7ECF5", "$type": "color" },
        "250": { "$value": "#AAB4C8", "$type": "color" },
        "400": { "$value": "#7A859C", "$type": "color" },
        "600": { "$value": "#4A5873", "$type": "color" },
        "700": { "$value": "#3A465D", "$type": "color" },
        "800": { "$value": "#2A3446", "$type": "color" },
        "850": { "$value": "#202838", "$type": "color" },
        "900": { "$value": "#171D28", "$type": "color" },
        "925": { "$value": "#10141B", "$type": "color" },
        "950": { "$value": "#07080C", "$type": "color" }
      },
      "blue": {
        "400": { "$value": "#7AA4FF", "$type": "color" },
        "500": { "$value": "#5B8CFF", "$type": "color" }
      },
      "green": {
        "400": { "$value": "#4ADE80", "$type": "color" }
      },
      "red": {
        "400": { "$value": "#FF6B7A", "$type": "color" }
      },
      "orange": {
        "400": { "$value": "#F6B24A", "$type": "color" }
      },
      "cyan": {
        "400": { "$value": "#46C9F5", "$type": "color" }
      },
      "pink": {
        "500": { "$value": "#FF4D6D", "$type": "color" }
      }
    },
    "font": {
      "family": {
        "sans": {
          "$value": "\"Inter\", \"PingFang SC\", system-ui, sans-serif",
          "$type": "fontFamily"
        },
        "numeric": {
          "$value": "\"JetBrains Mono\", \"IBM Plex Mono\", ui-monospace, monospace",
          "$type": "fontFamily"
        }
      },
      "size": {
        "11": { "$value": "11px", "$type": "fontSize" },
        "12": { "$value": "12px", "$type": "fontSize" },
        "13": { "$value": "13px", "$type": "fontSize" },
        "14": { "$value": "14px", "$type": "fontSize" },
        "16": { "$value": "16px", "$type": "fontSize" },
        "18": { "$value": "18px", "$type": "fontSize" },
        "20": { "$value": "20px", "$type": "fontSize" },
        "24": { "$value": "24px", "$type": "fontSize" },
        "32": { "$value": "32px", "$type": "fontSize" }
      },
      "weight": {
        "400": { "$value": "400", "$type": "fontWeight" },
        "500": { "$value": "500", "$type": "fontWeight" },
        "600": { "$value": "600", "$type": "fontWeight" },
        "700": { "$value": "700", "$type": "fontWeight" }
      }
    },
    "lineHeight": {
      "body": { "$value": "1.5", "$type": "number" },
      "numeric": { "$value": "1.2", "$type": "number" },
      "heading": { "$value": "1.25", "$type": "number" }
    },
    "space": {
      "2": { "$value": "2px", "$type": "dimension" },
      "4": { "$value": "4px", "$type": "dimension" },
      "6": { "$value": "6px", "$type": "dimension" },
      "8": { "$value": "8px", "$type": "dimension" },
      "12": { "$value": "12px", "$type": "dimension" },
      "16": { "$value": "16px", "$type": "dimension" },
      "20": { "$value": "20px", "$type": "dimension" },
      "24": { "$value": "24px", "$type": "dimension" },
      "32": { "$value": "32px", "$type": "dimension" },
      "40": { "$value": "40px", "$type": "dimension" },
      "48": { "$value": "48px", "$type": "dimension" }
    },
    "radius": {
      "4": { "$value": "4px", "$type": "borderRadius" },
      "8": { "$value": "8px", "$type": "borderRadius" },
      "12": { "$value": "12px", "$type": "borderRadius" },
      "16": { "$value": "16px", "$type": "borderRadius" },
      "999": { "$value": "999px", "$type": "borderRadius" }
    },
    "borderWidth": {
      "1": { "$value": "1px", "$type": "borderWidth" },
      "2": { "$value": "2px", "$type": "borderWidth" }
    },
    "shadow": {
      "overlay": {
        "$value": "0 16px 48px rgba(0, 0, 0, 0.42), 0 1px 0 rgba(255, 255, 255, 0.04) inset",
        "$type": "shadow"
      }
    },
    "motion": {
      "duration": {
        "120": { "$value": "120ms", "$type": "duration" },
        "180": { "$value": "180ms", "$type": "duration" },
        "240": { "$value": "240ms", "$type": "duration" },
        "2400": { "$value": "2400ms", "$type": "duration" }
      },
      "easing": {
        "standard": {
          "$value": "cubic-bezier(0.2, 0.8, 0.2, 1)",
          "$type": "cubicBezier"
        },
        "out": {
          "$value": "ease-out",
          "$type": "cubicBezier"
        },
        "inOut": {
          "$value": "ease-in-out",
          "$type": "cubicBezier"
        }
      }
    }
  },
  "alias": {
    "color": {
      "bg": {
        "0": { "$value": "{global.color.neutral.950}", "$type": "color" },
        "1": { "$value": "{global.color.neutral.925}", "$type": "color" },
        "2": { "$value": "{global.color.neutral.900}", "$type": "color" },
        "3": { "$value": "{global.color.neutral.850}", "$type": "color" }
      },
      "border": {
        "subtle": { "$value": "{global.color.neutral.800}", "$type": "color" },
        "regular": { "$value": "{global.color.neutral.700}", "$type": "color" },
        "strong": { "$value": "{global.color.neutral.600}", "$type": "color" }
      },
      "text": {
        "primary": { "$value": "{global.color.neutral.100}", "$type": "color" },
        "secondary": { "$value": "{global.color.neutral.250}", "$type": "color" },
        "tertiary": { "$value": "{global.color.neutral.400}", "$type": "color" },
        "disabled": { "$value": "{global.color.neutral.600}", "$type": "color" }
      },
      "brand": {
        "primary": { "$value": "{global.color.blue.500}", "$type": "color" },
        "hover": { "$value": "{global.color.blue.400}", "$type": "color" },
        "soft": { "$value": "rgba(91, 140, 255, 0.14)", "$type": "color" }
      },
      "up": {
        "main": { "$value": "{global.color.green.400}", "$type": "color" },
        "soft": { "$value": "rgba(74, 222, 128, 0.14)", "$type": "color" }
      },
      "down": {
        "main": { "$value": "{global.color.red.400}", "$type": "color" },
        "soft": { "$value": "rgba(255, 107, 122, 0.14)", "$type": "color" }
      },
      "risk": {
        "low": { "$value": "{global.color.green.400}", "$type": "color" },
        "medium": { "$value": "{global.color.orange.400}", "$type": "color" },
        "high": { "$value": "{global.color.red.400}", "$type": "color" },
        "liquidation": { "$value": "{global.color.pink.500}", "$type": "color" }
      },
      "state": {
        "warn": { "$value": "{global.color.orange.400}", "$type": "color" },
        "info": { "$value": "{global.color.cyan.400}", "$type": "color" },
        "success": { "$value": "{global.color.green.400}", "$type": "color" },
        "danger": { "$value": "{global.color.red.400}", "$type": "color" }
      },
      "stale": { "$value": "{global.color.neutral.400}", "$type": "color" },
      "focus": { "$value": "{global.color.blue.400}", "$type": "color" },
      "overlay": {
        "scrim": { "$value": "rgba(4, 6, 10, 0.72)", "$type": "color" }
      }
    },
    "font": {
      "family": {
        "body": { "$value": "{global.font.family.sans}", "$type": "fontFamily" },
        "numeric": {
          "$value": "{global.font.family.numeric}",
          "$type": "fontFamily"
        }
      },
      "size": {
        "caption": { "$value": "{global.font.size.11}", "$type": "fontSize" },
        "label": { "$value": "{global.font.size.12}", "$type": "fontSize" },
        "body": { "$value": "{global.font.size.14}", "$type": "fontSize" },
        "price": { "$value": "{global.font.size.16}", "$type": "fontSize" },
        "section": { "$value": "{global.font.size.20}", "$type": "fontSize" },
        "hero": { "$value": "{global.font.size.32}", "$type": "fontSize" }
      },
      "weight": {
        "regular": { "$value": "{global.font.weight.400}", "$type": "fontWeight" },
        "medium": { "$value": "{global.font.weight.500}", "$type": "fontWeight" },
        "semibold": { "$value": "{global.font.weight.600}", "$type": "fontWeight" },
        "bold": { "$value": "{global.font.weight.700}", "$type": "fontWeight" }
      }
    },
    "lineHeight": {
      "body": { "$value": "{global.lineHeight.body}", "$type": "number" },
      "numeric": { "$value": "{global.lineHeight.numeric}", "$type": "number" },
      "heading": { "$value": "{global.lineHeight.heading}", "$type": "number" }
    },
    "radius": {
      "sm": { "$value": "{global.radius.4}", "$type": "borderRadius" },
      "md": { "$value": "{global.radius.8}", "$type": "borderRadius" },
      "lg": { "$value": "{global.radius.12}", "$type": "borderRadius" },
      "xl": { "$value": "{global.radius.16}", "$type": "borderRadius" },
      "pill": { "$value": "{global.radius.999}", "$type": "borderRadius" }
    }
  },
  "component": {
    "button": {
      "primary": {
        "bg": {
          "default": { "$value": "{alias.color.brand.primary}", "$type": "color" },
          "hover": { "$value": "{alias.color.brand.hover}", "$type": "color" },
          "disabled": { "$value": "{alias.color.bg.3}", "$type": "color" }
        },
        "text": {
          "default": { "$value": "{global.color.neutral.0}", "$type": "color" },
          "disabled": { "$value": "{alias.color.text.disabled}", "$type": "color" }
        }
      },
      "secondary": {
        "bg": {
          "default": { "$value": "{alias.color.bg.2}", "$type": "color" },
          "hover": { "$value": "{alias.color.bg.3}", "$type": "color" }
        },
        "border": {
          "default": { "$value": "{alias.color.border.regular}", "$type": "color" }
        },
        "text": {
          "default": { "$value": "{alias.color.text.primary}", "$type": "color" }
        }
      },
      "ghost": {
        "bg": {
          "default": { "$value": "rgba(0, 0, 0, 0)", "$type": "color" },
          "hover": { "$value": "{alias.color.bg.2}", "$type": "color" }
        },
        "text": {
          "default": { "$value": "{alias.color.text.secondary}", "$type": "color" }
        }
      },
      "danger": {
        "bg": {
          "default": { "$value": "{alias.color.state.danger}", "$type": "color" },
          "hover": { "$value": "{alias.color.risk.liquidation}", "$type": "color" }
        },
        "text": {
          "default": { "$value": "{global.color.neutral.0}", "$type": "color" }
        }
      }
    },
    "input": {
      "bg": {
        "default": { "$value": "{alias.color.bg.3}", "$type": "color" }
      },
      "border": {
        "default": { "$value": "{alias.color.border.regular}", "$type": "color" },
        "focus": { "$value": "{alias.color.focus}", "$type": "color" },
        "error": { "$value": "{alias.color.state.danger}", "$type": "color" }
      },
      "text": {
        "default": { "$value": "{alias.color.text.primary}", "$type": "color" },
        "placeholder": { "$value": "{alias.color.text.tertiary}", "$type": "color" }
      }
    },
    "tabs": {
      "track": {
        "bg": { "$value": "{alias.color.bg.2}", "$type": "color" }
      },
      "item": {
        "active": {
          "bg": { "$value": "{alias.color.bg.3}", "$type": "color" },
          "border": { "$value": "{alias.color.brand.primary}", "$type": "color" },
          "text": { "$value": "{alias.color.text.primary}", "$type": "color" }
        },
        "inactive": {
          "text": { "$value": "{alias.color.text.secondary}", "$type": "color" }
        }
      }
    },
    "modal": {
      "bg": { "$value": "{alias.color.bg.2}", "$type": "color" },
      "border": { "$value": "{alias.color.border.regular}", "$type": "color" },
      "overlay": { "$value": "{alias.color.overlay.scrim}", "$type": "color" },
      "shadow": { "$value": "{global.shadow.overlay}", "$type": "shadow" }
    },
    "banner": {
      "info": {
        "bg": { "$value": "rgba(70, 201, 245, 0.12)", "$type": "color" },
        "border": { "$value": "{alias.color.state.info}", "$type": "color" },
        "text": { "$value": "{alias.color.text.primary}", "$type": "color" }
      },
      "warn": {
        "bg": { "$value": "rgba(246, 178, 74, 0.14)", "$type": "color" },
        "border": { "$value": "{alias.color.state.warn}", "$type": "color" },
        "text": { "$value": "{alias.color.text.primary}", "$type": "color" }
      },
      "danger": {
        "bg": { "$value": "rgba(255, 107, 122, 0.14)", "$type": "color" },
        "border": { "$value": "{alias.color.state.danger}", "$type": "color" },
        "text": { "$value": "{alias.color.text.primary}", "$type": "color" }
      }
    },
    "toast": {
      "bg": { "$value": "{alias.color.bg.2}", "$type": "color" },
      "border": { "$value": "{alias.color.border.regular}", "$type": "color" },
      "shadow": { "$value": "{global.shadow.overlay}", "$type": "shadow" }
    },
    "skeleton": {
      "base": { "$value": "{alias.color.bg.2}", "$type": "color" },
      "shine": { "$value": "{alias.color.bg.3}", "$type": "color" }
    },
    "priceTicker": {
      "value": {
        "up": { "$value": "{alias.color.up.main}", "$type": "color" },
        "down": { "$value": "{alias.color.down.main}", "$type": "color" },
        "flat": { "$value": "{alias.color.text.secondary}", "$type": "color" }
      },
      "flash": {
        "up": { "$value": "{alias.color.up.soft}", "$type": "color" },
        "down": { "$value": "{alias.color.down.soft}", "$type": "color" }
      }
    },
    "klineChart": {
      "grid": { "$value": "{alias.color.border.subtle}", "$type": "color" },
      "candle": {
        "up": { "$value": "{alias.color.up.main}", "$type": "color" },
        "down": { "$value": "{alias.color.down.main}", "$type": "color" }
      },
      "crosshair": { "$value": "{alias.color.stale}", "$type": "color" }
    },
    "orderBook": {
      "bid": { "$value": "{alias.color.up.soft}", "$type": "color" },
      "ask": { "$value": "{alias.color.down.soft}", "$type": "color" },
      "grid": { "$value": "{alias.color.border.subtle}", "$type": "color" }
    },
    "orderForm": {
      "panel": {
        "bg": { "$value": "{alias.color.bg.1}", "$type": "color" },
        "border": { "$value": "{alias.color.border.regular}", "$type": "color" }
      },
      "submit": {
        "buy": { "$value": "{alias.color.up.main}", "$type": "color" },
        "sell": { "$value": "{alias.color.down.main}", "$type": "color" }
      },
      "risk": {
        "low": { "$value": "{alias.color.risk.low}", "$type": "color" },
        "medium": { "$value": "{alias.color.risk.medium}", "$type": "color" },
        "high": { "$value": "{alias.color.risk.high}", "$type": "color" },
        "liquidation": {
          "$value": "{alias.color.risk.liquidation}",
          "$type": "color"
        }
      }
    },
    "position": {
      "row": {
        "bg": {
          "default": { "$value": "{alias.color.bg.1}", "$type": "color" },
          "liquidation": { "$value": "rgba(255, 77, 109, 0.12)", "$type": "color" }
        },
        "border": { "$value": "{alias.color.border.regular}", "$type": "color" }
      },
      "pnl": {
        "up": { "$value": "{alias.color.up.main}", "$type": "color" },
        "down": { "$value": "{alias.color.down.main}", "$type": "color" },
        "flat": { "$value": "{alias.color.text.secondary}", "$type": "color" }
      }
    },
    "marginRing": {
      "track": { "$value": "{alias.color.bg.3}", "$type": "color" },
      "low": { "$value": "{alias.color.risk.low}", "$type": "color" },
      "medium": { "$value": "{alias.color.risk.medium}", "$type": "color" },
      "high": { "$value": "{alias.color.risk.high}", "$type": "color" },
      "liquidation": { "$value": "{alias.color.risk.liquidation}", "$type": "color" }
    },
    "quoteStalenessBadge": {
      "bg": { "$value": "rgba(122, 133, 156, 0.16)", "$type": "color" },
      "border": { "$value": "{alias.color.stale}", "$type": "color" },
      "text": { "$value": "{alias.color.stale}", "$type": "color" }
    },
    "depositStepper": {
      "track": { "$value": "{alias.color.bg.3}", "$type": "color" },
      "step": {
        "active": { "$value": "{alias.color.brand.primary}", "$type": "color" },
        "complete": { "$value": "{alias.color.up.main}", "$type": "color" },
        "pending": { "$value": "{alias.color.bg.2}", "$type": "color" }
      }
    },
    "userStatusPill": {
      "pending": {
        "bg": { "$value": "rgba(246, 178, 74, 0.14)", "$type": "color" },
        "text": { "$value": "{alias.color.state.warn}", "$type": "color" }
      },
      "active": {
        "bg": { "$value": "{alias.color.up.soft}", "$type": "color" },
        "text": { "$value": "{alias.color.up.main}", "$type": "color" }
      },
      "frozen": {
        "bg": { "$value": "{alias.color.down.soft}", "$type": "color" },
        "text": { "$value": "{alias.color.down.main}", "$type": "color" }
      },
      "banned": {
        "bg": { "$value": "rgba(255, 77, 109, 0.18)", "$type": "color" },
        "text": { "$value": "{alias.color.risk.liquidation}", "$type": "color" }
      }
    },
    "traceIdTag": {
      "bg": { "$value": "{alias.color.bg.3}", "$type": "color" },
      "border": { "$value": "{alias.color.border.regular}", "$type": "color" },
      "text": { "$value": "{alias.color.text.secondary}", "$type": "color" }
    }
  }
}
