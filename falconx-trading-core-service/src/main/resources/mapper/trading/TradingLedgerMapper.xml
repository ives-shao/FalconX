<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.falconx.trading.repository.mapper.TradingLedgerMapper">

    <resultMap id="tradingLedgerRecordMap" type="com.falconx.trading.repository.mapper.record.TradingLedgerRecord">
        <constructor>
            <idArg column="id" javaType="java.lang.Long"/>
            <arg column="user_id" javaType="java.lang.Long"/>
            <arg column="account_id" javaType="java.lang.Long"/>
            <arg column="biz_type" javaType="java.lang.Integer"/>
            <arg column="idempotency_key" javaType="java.lang.String"/>
            <arg column="reference_no" javaType="java.lang.String"/>
            <arg column="amount" javaType="java.math.BigDecimal"/>
            <arg column="balance_before" javaType="java.math.BigDecimal"/>
            <arg column="balance_after" javaType="java.math.BigDecimal"/>
            <arg column="frozen_before" javaType="java.math.BigDecimal"/>
            <arg column="frozen_after" javaType="java.math.BigDecimal"/>
            <arg column="margin_used_before" javaType="java.math.BigDecimal"/>
            <arg column="margin_used_after" javaType="java.math.BigDecimal"/>
            <arg column="created_at" javaType="java.time.LocalDateTime"/>
        </constructor>
    </resultMap>

    <insert id="insertTradingLedger" parameterType="com.falconx.trading.repository.mapper.record.TradingLedgerRecord">
        INSERT INTO t_ledger (
            id,
            user_id,
            account_id,
            biz_type,
            idempotency_key,
            reference_no,
            amount,
            balance_before,
            balance_after,
            frozen_before,
            frozen_after,
            margin_used_before,
            margin_used_after,
            created_at
        ) VALUES (
            #{id},
            #{userId},
            #{accountId},
            #{bizTypeCode},
            #{idempotencyKey},
            #{referenceNo},
            #{amount},
            #{balanceBefore},
            #{balanceAfter},
            #{frozenBefore},
            #{frozenAfter},
            #{marginUsedBefore},
            #{marginUsedAfter},
            #{createdAt}
        )
    </insert>

    <select id="selectByUserId" resultMap="tradingLedgerRecordMap">
        SELECT id,
               user_id,
               account_id,
               biz_type,
               idempotency_key,
               reference_no,
               amount,
               balance_before,
               balance_after,
               frozen_before,
               frozen_after,
               margin_used_before,
               margin_used_after,
               created_at
        FROM t_ledger
        WHERE user_id = #{userId}
        ORDER BY created_at ASC, id ASC
        LIMIT 1000
    </select>

    <select id="selectByUserIdPaginated" resultMap="tradingLedgerRecordMap">
        SELECT id,
               user_id,
               account_id,
               biz_type,
               idempotency_key,
               reference_no,
               amount,
               balance_before,
               balance_after,
               frozen_before,
               frozen_after,
               margin_used_before,
               margin_used_after,
               created_at
        FROM t_ledger
        WHERE user_id = #{userId}
        ORDER BY created_at ASC, id ASC
        LIMIT #{limit} OFFSET #{offset}
    </select>
</mapper>
