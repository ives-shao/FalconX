<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.falconx.trading.repository.mapper.TradingRiskConfigMapper">

    <resultMap id="tradingRiskConfigRecordMap" type="com.falconx.trading.repository.mapper.record.TradingRiskConfigRecord">
        <constructor>
            <idArg column="id" javaType="java.lang.Long"/>
            <arg column="symbol" javaType="java.lang.String"/>
            <arg column="max_position_per_user" javaType="java.math.BigDecimal"/>
            <arg column="max_position_total" javaType="java.math.BigDecimal"/>
            <arg column="maintenance_margin_rate" javaType="java.math.BigDecimal"/>
            <arg column="max_leverage" javaType="java.lang.Integer"/>
            <arg column="hedge_threshold_usd" javaType="java.math.BigDecimal"/>
            <arg column="created_at" javaType="java.time.LocalDateTime"/>
            <arg column="updated_at" javaType="java.time.LocalDateTime"/>
        </constructor>
    </resultMap>

    <select id="selectBySymbol" resultMap="tradingRiskConfigRecordMap">
        SELECT id,
               symbol,
               max_position_per_user,
               max_position_total,
               maintenance_margin_rate,
               max_leverage,
               hedge_threshold_usd,
               created_at,
               updated_at
        FROM t_risk_config
        WHERE symbol = #{symbol}
    </select>
</mapper>
