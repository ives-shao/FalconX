<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.falconx.trading.repository.mapper.TradingDepositMapper">

    <resultMap id="tradingDepositRecordMap" type="com.falconx.trading.repository.mapper.record.TradingDepositRecord">
        <constructor>
            <idArg column="id" javaType="java.lang.Long"/>
            <arg column="user_id" javaType="java.lang.Long"/>
            <arg column="account_id" javaType="java.lang.Long"/>
            <arg column="chain" javaType="java.lang.String"/>
            <arg column="token" javaType="java.lang.String"/>
            <arg column="tx_hash" javaType="java.lang.String"/>
            <arg column="amount" javaType="java.math.BigDecimal"/>
            <arg column="status" javaType="java.lang.Integer"/>
            <arg column="credited_at" javaType="java.time.LocalDateTime"/>
            <arg column="reversed_at" javaType="java.time.LocalDateTime"/>
            <arg column="created_at" javaType="java.time.LocalDateTime"/>
        </constructor>
    </resultMap>

    <select id="selectByChainAndTxHash" resultMap="tradingDepositRecordMap">
        SELECT id, user_id, account_id, chain, token, tx_hash, amount, status, credited_at, reversed_at, created_at
        FROM t_deposit
        WHERE chain = #{chain}
          AND tx_hash = #{txHash}
    </select>

    <insert id="insertTradingDeposit" parameterType="com.falconx.trading.repository.mapper.record.TradingDepositRecord">
        INSERT INTO t_deposit (
            id,
            user_id,
            account_id,
            chain,
            token,
            tx_hash,
            amount,
            status,
            credited_at,
            reversed_at,
            created_at
        ) VALUES (
            #{id},
            #{userId},
            #{accountId},
            #{chain},
            #{token},
            #{txHash},
            #{amount},
            #{statusCode},
            #{creditedAt},
            #{reversedAt},
            #{createdAt}
        )
    </insert>

    <update id="updateTradingDeposit" parameterType="com.falconx.trading.repository.mapper.record.TradingDepositRecord">
        UPDATE t_deposit
        SET user_id = #{userId},
            account_id = #{accountId},
            token = #{token},
            amount = #{amount},
            status = #{statusCode},
            credited_at = #{creditedAt},
            reversed_at = #{reversedAt}
        WHERE id = #{id}
    </update>
</mapper>
